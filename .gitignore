# R session artifacts
.Rproj.user
.Rhistory
.RData
.Ruserdata
**/.Rhistory
**/.RData

# Temp / lock files
~$*
*.tmp

# macOS
.DS_Store
**/.DS_Store

# Knitr cache (regenerated on wflow_build)
*_cache/

# Large generated outputs (regenerated by running the pipeline)
output/

# Large genotype files (not redistributable; obtain from original source)
data/geno/*.hmp.txt
data/geno/*.hmp_v3.txt
data/geno/*.vcf
data/geno/*.ped
data/geno/*.map
data/geno/*.log
data/geno/*.nosex
data/geno/PLINK_*/
data/geno/RIL/VCF/
.positai
