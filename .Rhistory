#load libraries - BE SURE THEY ARE UPDATED
library(httr)
library(jsonlite)
library(xml2)
library(dplyr)
parse_gff_content <- function(gff_content) {
#Function that processes the .gff output gathered from the annotations in Ensembl to just include gene names. To get the full .gff report you can just delete this function and run the script
lines <- strsplit(gff_content, "\n")[[1]]
# Extract only lines that are genes
gene_lines <- grep("\tgene\t", lines, value = TRUE)
# Extract gene IDs using regex on attributes column
gene_ids <- sub(".*?ID=gene:(.*?);.*", "\\1", gene_lines)
return(gene_ids)
}
extract_candidates_snp<- function(SNPs,species,flank_length,output_file){
#Arguments:
#SNPs- Data Frame of chromosome number in column 1 and SNP positions in column 2, make sure these positions are gathered from the correct version of the reference genome
#species- Name of species from Ensembl Plants; Triticum_aestivum for wheat and Hordeum_vulgare for barley
#flank_length- Desired length of flanking region desired to be scanned for candidate genes
#output_file- desired name of the output csv
#Returns:
#candidate genes- .gff dataframe off all the candidates in the region
candidate_genes <- data.frame(neighboring_snp = integer(), candidate_gene = character(), stringsAsFactors = FALSE)
server <- "https://rest.ensembl.org"
# Ensembl Plants barley chromosomes are named "1H", "2H", etc.
chrom_suffix <- if (grepl("hordeum_vulgare", tolower(species))) "H" else ""
for (i in 1:nrow(SNPs)){
current_chrom <- paste0(SNPs[i,1], chrom_suffix)
current_snp <- as.numeric(SNPs[i,2])
start_bp <- current_snp-flank_length
end_bp <- current_snp+flank_length
ext <- paste("/overlap/region/", tolower(species), "/", current_chrom, ":", format(start_bp, scientific = FALSE), "-", format(end_bp, scientific = FALSE), "?", "feature=gene", sep="")
request <- GET(paste(server, ext, sep = ""), content_type("text/x-gff3"))
stop_for_status(request)
gff_content <- content(request, "text")
parsed_genes <- parse_gff_content(gff_content) #utilizes parsed_gff_content function below to extract gene names. If you want the full content from the .gff code delete this line and the one above
candidate_genes <- rbind(candidate_genes,
data.frame(neighboring_snp = current_snp,
candidate_gene = as.character(parsed_genes), #if you don't want parsed .gff content, do genes=as.character(content(response))
stringsAsFactors = FALSE))
}
write.table(candidate_genes, file = output_file, sep = ",", row.names = FALSE, col.names = TRUE, quote = FALSE)
}
