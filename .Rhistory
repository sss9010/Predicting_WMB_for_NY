S.T              = "S.T",
DP..ASBC.       = "DP",
Alpha.amylase.20.DU. = "AA",
Beta.glucan.ppm. = "BG",
HD_JD = "HD",
yield_kgha = "GY",
FAN.ppm.         = "FAN",
