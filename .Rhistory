color       = colorRampPalette(c("white","#2166AC"))(50),
cluster_rows = TRUE, cluster_cols = FALSE,
main        = "Relative Band Importance for each Synthetic VI",
fontsize     = 10)
} else {
sensitivity_list %>%
ggplot(aes(x = band, y = reorder(trait, importance),
fill = importance)) +
