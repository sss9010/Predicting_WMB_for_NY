) +
theme_minimal() +
theme(
plot.title = element_text(hjust = 0.5, size = 14),
strip.text = element_text(size = 12)
) +
# Add correlation information to each facet (for display only)
ggpubr::stat_cor(method = "pearson", label.x.npc = "left", label.y.npc = "top")
print(p)
}
VIs <- colnames(data_all)[22:31]
MQtraits<- colnames(data_all)[38:54]
agtraits<- colnames(data_all)[17:20]
traits<- c(MQtraits, agtraits)
# Pivot the data so that all trait columns are gathered into two columns:
# one for the trait names and one for the trait values.
df_long <- df_tp %>%
pivot_longer(
cols = all_of(traits),
names_to = "trait",
values_to = "trait_value"
)
str(data_all)
data_all<- data_all %>% filter(!WortColor == "n.d.")
str(data_all)
is.na(data_all)
table(is.na(data_all))
colnames(data_all)[17:20]
data_all<- data_all %>% filter(!WortColor == "n.d.")
# Create an empty dataframe to store correlation results
cor_results_df <- data.frame(timepoint = character(),
VI = character(),
trait = character(),
correlation = numeric(),
stringsAsFactors = FALSE)
# Get unique timepoints from your dataframe
timepoints <- unique(data_all$timepoint)
data_all$Env<- as.character(data_all$Env)
data_all$Env<-as.factor(data_all$Env)
envs<- levels(data_all$Env)
for (e in envs) {
data<- data_all %>% filter(Env == e)
# Loop through each timepoint
for (tp in timepoints) {
# Filter the data for the current timepoint
df_tp <- data %>% filter(timepoint == tp)
# Loop through each VI in your VIs vector
for (vi in VIs) {
# Pivot the data so that all trait columns are gathered into two columns:
# one for the trait names and one for the trait values.
df_long <- df_tp %>%
pivot_longer(
cols = all_of(traits),
names_to = "trait",
values_to = "trait_value"
)
# Calculate correlation for each trait with the current VI
# Note: .data[[vi]] is used to reference the column by name stored in vi.
corr_summary <- df_long %>%
group_by(trait) %>%
summarise(correlation = cor(trait_value, .data[[vi]], use = "complete.obs"),
.groups = "drop") %>%
mutate(timepoint = tp,
VI = vi) #%>%
#select(timepoint, VI, trait, correlation)
# Append the correlation summary to our results dataframe
cor_results_df <- rbind(cor_results_df, corr_summary)
# Create a scatter plot with a linear model smooth line, faceted by trait
p <- ggplot(df_long, aes(x = trait_value, y = .data[[vi]])) +
geom_point(alpha = 0.2) +
geom_smooth(method = "lm", se = FALSE, color = "blue", linewidth = 0.8) +
facet_wrap(~ trait, scales = "free_x") +
labs(
title = paste("Timepoint:", tp, "| VI:", vi),
x = "Trait Value",
y = vi
) +
theme_minimal() +
theme(
plot.title = element_text(hjust = 0.5, size = 14),
strip.text = element_text(size = 12)
) +
# Add correlation information to each facet (for display only)
ggpubr::stat_cor(method = "pearson", label.x.npc = "left", label.y.npc = "top")
print(p)
}
}
}
