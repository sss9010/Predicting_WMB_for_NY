# Chunk 1: setup
knitr::opts_chunk$set(echo = TRUE)
# Chunk 2
load("C:/Users/Siim Sepp/NY_WMB/data/VImat.Rdata")
names(VImats)
names(VImats$KET21)
#load("C:/Users/Siim Sepp/NY_WMB/data/VImatBLUP.Rdata")
# Chunk 3
library(fdapace)
library(ggplot2)
library(dplyr)
library(tidyr)
# Storage lists
PCA_results <- list()
FPCA_results <- list()
# Loop over environments and VIs
for (env in names(VImats)) {
PCA_results[[env]] <- list()
FPCA_results[[env]] <- list()
mats<- names(VImats[[env]])[-11]
for (vi in mats) {
df <- VImats[[env]][[vi]] %>% na.omit()
# Assume first column is GID
rownames(df) <- df$plot_id
mat <- df[, -1]
mat_scaled <- scale(mat)
# PCA
pca <- prcomp(mat_scaled, center = FALSE, scale. = FALSE)
PCA_results[[env]][[vi]] <- pca
# --- PCA Plots ---
# Scree
pca_var <- pca$sdev^2
pca_df <- data.frame(PC = paste0("PC", 1:length(pca_var)),
Variance = pca_var / sum(pca_var))
print(ggplot(pca_df, aes(x = PC, y = Variance)) +
geom_col(fill = "steelblue") +
ggtitle(paste("PCA Scree -", env, vi)))
# Loadings
loadings <- as.data.frame(pca$rotation)
loadings$Timepoint <- as.numeric(gsub("[^0-9]", "", colnames(mat)))
print(ggplot(loadings, aes(x = Timepoint, y = PC1)) +
geom_line() + geom_point() +
ggtitle(paste("PCA Loadings PC1 -", env, vi)))
# Scores
scores <- as.data.frame(pca$x)
scores$GID <- rownames(scores)
print(ggplot(scores, aes(x = PC1, y = PC2)) +
geom_point() +
ggtitle(paste("PCA Scores -", env, vi)))
# FPCA prep
long_df <- df %>%
pivot_longer(-plot_id, names_to = "Time", values_to = "value") %>%
mutate(Time = as.numeric(gsub("[^0-9]", "", Time)))
Ly <- split(long_df$value, long_df$plot_id)
Lt <- split(long_df$Time, long_df$plot_id)
# FPCA
fpca <- FPCA(Ly = Ly, Lt = Lt, optns = list(dataType = 'Sparse', methodSelectK = 3))
FPCA_results[[env]][[vi]] <- fpca
# --- FPCA Plots ---
eigen_df <- data.frame(Time = fpca$workGrid,
FPC1 = fpca$phi[, 1],
FPC2 = fpca$phi[, 2],
FPC3 = fpca$phi[, 2])
print(ggplot(eigen_df, aes(x = Time)) +
geom_line(aes(y = FPC1), color = "forestgreen") +
geom_line(aes(y = FPC2), color = "orange") +
geom_line(aes(y = FPC3), color = "brown") +
ggtitle(paste("FPCA Eigenfunctions -", env, vi)))
scores_fpca <- as.data.frame(fpca$xiEst)
colnames(scores_fpca) <- paste0("FPC", 1:ncol(scores_fpca))
scores_fpca$GID <- names(fpca$xiEst)
print(ggplot(scores_fpca, aes(x = FPC1, y = FPC2)) +
geom_point(color = "darkorange") +
ggtitle(paste("FPCA Scores -", env, vi)))
}
}
PCA_results_raw<- PCA_results
FPCA_results_raw <- FPCA_results
# Chunk 4
