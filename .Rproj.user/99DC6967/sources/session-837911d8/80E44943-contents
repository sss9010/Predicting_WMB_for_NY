**8. Sparse testing CV2**

```{r}
run_bivariate_gblup_cv2 <- function(data, A1,
                                    traits,       # response traits to predict (j)
                                    cor_traits,   # correlated helper traits (i)
                                    envs = NULL,
                                    reps = 5, folds = 5,
                                    spatial = FALSE,
                                    mask = c("j_only", "both", "i_only"),
                                    eig.tol = 1e-3) {
  mask <- match.arg(mask)

  safe_cor <- function(x, y) {
    ok <- stats::complete.cases(x, y)
    if (sum(ok) < 2) return(NA_real_)
    suppressWarnings(stats::cor(x[ok], y[ok]))
  }

  # env list
  if (is.null(envs)) envs <- if (is.factor(data$Env)) levels(data$Env) else sort(unique(data$Env))
  data <- data[data$Env %in% envs, , drop = FALSE]
  if (nrow(data) == 0L) stop("No data left after filtering envs.")

  # Basic columns
  if (!("GID" %in% names(data))) stop("data must contain column 'GID'")
  if (!("Env" %in% names(data))) stop("data must contain column 'Env'")

  # Align GIDs to A1 once (global)
  data$GID <- as.character(data$GID)
  keep_gids <- intersect(unique(data$GID), rownames(A1))
  data <- data[data$GID %in% keep_gids, , drop = FALSE]
  if (length(keep_gids) < 5) stop("Too few common GIDs between data and A1.")

  # Subset and invert/bend G matrix
  A1_sub    <- A1[keep_gids, keep_gids, drop = FALSE]
  Ghat.bend <- G.tuneup(G = A1_sub, bend = TRUE, eig.tol = eig.tol)$Gb
  Ginv      <- G.inverse(Ghat.bend, sparse = TRUE)$Ginv

  # Factors
  data$GID <- factor(data$GID, levels = keep_gids)
  data$Env <- factor(data$Env, levels = envs)

  has_spatial <- spatial && all(c("Row", "Column") %in% names(data))
  if (has_spatial) {
    data$Row    <- as.factor(data$Row)
    data$Column <- as.factor(data$Column)
  }

  res_all  <- data.frame()
  fail_log <- list()

  # Loop over trait pairs (i helps predict j)
  for (i in cor_traits) {
    for (j in traits) {
      if (i == j) next
      if (!(i %in% names(data)) || !(j %in% names(data))) next

      message("\nCV2 bivariate model: ", paste0("cbind(", i, ", ", j, ")  pooled across Env"))

      # Work on required columns only
      df_sub <- data[, unique(c("GID", "Env", if (has_spatial) c("Row", "Column") else NULL, i, j)), drop = FALSE]

      # Remove rows where BOTH traits are missing (nothing to contribute)
      ok_any <- !(is.na(df_sub[[i]]) & is.na(df_sub[[j]]))
      df_sub <- df_sub[ok_any, , drop = FALSE]
      if (nrow(df_sub) == 0L) next

      # CV2 folds assigned at GID level (crucial)
      gids <- levels(df_sub$GID)

      for (rep_run in seq_len(reps)) {
        set.seed(1000 + rep_run)

        fold_gid <- sample(rep(seq_len(folds), length.out = length(gids)))
        names(fold_gid) <- gids

        for (f in seq_len(folds)) {

          # Build long / stacked form (two traits)
          df_cv <- df_sub
          df_cv$units <- seq_len(nrow(df_cv))

          df_long <- rbind(
            data.frame(GID = df_cv$GID, Env = df_cv$Env,
                       Row = if (has_spatial) df_cv$Row else NA,
                       Column = if (has_spatial) df_cv$Column else NA,
                       trait = i, value = df_cv[[i]], units = df_cv$units,
                       stringsAsFactors = FALSE),
            data.frame(GID = df_cv$GID, Env = df_cv$Env,
                       Row = if (has_spatial) df_cv$Row else NA,
                       Column = if (has_spatial) df_cv$Column else NA,
                       trait = j, value = df_cv[[j]], units = df_cv$units,
                       stringsAsFactors = FALSE)
          )
          df_long$trait <- factor(df_long$trait, levels = c(i, j))

          # ---- CV2 masking: for each environment, hide only that env's records for test GIDs ----
          # test GIDs for this fold
          test_gids <- names(fold_gid)[fold_gid == f]
          test_gids <- factor(test_gids, levels = levels(df_long$GID))

          # mask trait values in an ENV-SPECIFIC way (CV2 sparse testing)
          # We mask j (or i / both) ONLY for GIDs in test_gids, separately within each Env.
          if (mask == "j_only") {
            df_long$value[df_long$trait == j & df_long$GID %in% test_gids] <- NA
          } else if (mask == "i_only") {
            df_long$value[df_long$trait == i & df_long$GID %in% test_gids] <- NA
          } else if (mask == "both") {
            df_long$value[df_long$GID %in% test_gids] <- NA
          }

          # Random genetic with 2x2 (co)variance across traits
          rand_formula <- ~ vm(GID, Ginv):corgh(trait)

          # Residual structure
          # Pooled across envs: simplest robust choice is idv(units).
          # If you want spatial: use Env-specific AR1xAR1 via at(Env) (ASReml supports this pattern).
          if (has_spatial) {
            rcov_formula <- ~ at(Env):ar1(Row):ar1(Column):units
          } else {
            rcov_formula <- ~ idv(units)
          }

          # Fit pooled model across Env
          mod_cv <- tryCatch({
            asreml(
              fixed     = value ~ trait + Env,   # allow env mean shifts (recommended in pooled model)
              random    = rand_formula,
              rcov      = rcov_formula,
              data      = df_long,
              na.action = list(x = "include", y = "include"),
              workspace = 1e8,
              maxit     = 100,
              ai.sing   = TRUE
            )
          }, error = function(e) e)

          if (inherits(mod_cv, "error")) {
            fail_log[[length(fail_log) + 1L]] <- data.frame(
              Trait = j, Cor_Trait = i, Rep = rep_run, Fold = f,
              Stage = "model", Error = mod_cv$message, stringsAsFactors = FALSE
            )
            next
          }

          # Predict BV for GID:trait, keep j
          pred_cv <- tryCatch({
            p <- predict(mod_cv, classify = "GID:trait")$pvals
            p <- p[p$trait == j, , drop = FALSE]
            names(p)[names(p) == "predicted.value"] <- "BV_cv"
            p
          }, error = function(e) e)

          if (inherits(pred_cv, "error") || is.null(pred_cv)) {
            fail_log[[length(fail_log) + 1L]] <- data.frame(
              Trait = j, Cor_Trait = i, Rep = rep_run, Fold = f,
              Stage = "predict", Error = if (inherits(pred_cv, "error")) pred_cv$message else "NULL preds",
              stringsAsFactors = FALSE
            )
            next
          }

          # ---- Evaluate CV2: ONLY the masked cells (Env x test GIDs) for trait j ----
          # "Truth" = original observed j values for those GIDs within each Env
          truth <- df_sub[df_sub$GID %in% test_gids, c("GID", "Env", j), drop = FALSE]
          colnames(truth)[3] <- "true"
          truth <- truth[!is.na(truth$true), , drop = FALSE]
          if (nrow(truth) < 2) next

          # merge predicted BV by GID
          merged <- merge(truth, pred_cv[, c("GID", "BV_cv")], by = "GID", all = FALSE)
          if (nrow(merged) < 2) next

          # CV2 results reported per ENV (since masking is env-specific conceptually)
          # Here we compute accuracy within each environment for this fold.
          for (e in levels(truth$Env)) {
            m_e <- merged[merged$Env == e, , drop = FALSE]
            cor_val <- if (nrow(m_e) >= 2) safe_cor(m_e$BV_cv, m_e$true) else NA_real_

            res_all <- rbind(res_all, data.frame(
              Env = e, Trait = j, Cor_Trait = i, Rep = rep_run, Fold = f,
              n_test = nrow(m_e),
              Cor = cor_val,
              stringsAsFactors = FALSE
            ))
          }
        }
      }
    }
  }

  list(
    results  = res_all,
    failures = if (length(fail_log)) do.call(rbind, fail_log) else NULL
  )
}

