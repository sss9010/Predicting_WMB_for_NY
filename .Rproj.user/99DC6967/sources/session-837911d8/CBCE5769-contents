# Extract Synthetic VIs (Full-Data Models)

For each trait we retrain on the full dataset and extract the Synthetic VI value
for every observation.

```{r extract-synthetic-vi, cache=TRUE}
synthetic_vi_list <- map(usable_traits, function(trait) {
  cat("Extracting Synthetic VI for trait:", trait, "\n")
  model <- tryCatch(
    train_model(model_data, trait, n_envs = n_envs,
                epochs = 150, lr = 5e-3, batch_size = 128),
    error = function(e) { message(e$message); NULL }
  )
  if (is.null(model)) return(rep(NA_real_, nrow(model_data)))

  bands_t <- torch_tensor(as.matrix(model_data[, BAND_NAMES, drop = FALSE]),
                          dtype = torch_float())
  with_no_grad({
    vi_vals <- model$get_synthetic_vi(bands_t)$squeeze()$to(device = "cpu")
  })
  as.numeric(vi_vals)
}) %>% set_names(paste0("SynVI_", usable_traits))

