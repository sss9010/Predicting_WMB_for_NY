# Comparison: Synthetic VI vs. Standard VIs

For each trait we compare the LOEO r of the Synthetic VI to the best standard VI
(linear regression of the best standard VI → trait, same LOEO folds).

```{r standard-vi-cv}
# Simple linear regression benchmark for each standard VI × trait
linreg_cv <- function(data, vi, trait) {
  map_dbl(env_levels, function(test_env) {
    tr  <- data %>% filter(Env != test_env,
                           !is.na(.data[[vi]]), !is.na(.data[[trait]]))
    te  <- data %>% filter(Env == test_env,
                           !is.na(.data[[vi]]), !is.na(.data[[trait]]))
    if (nrow(tr) < 10 || nrow(te) < 2) return(NA_real_)
    fit  <- lm(as.formula(paste(trait, "~", vi, "+ Env")), data = tr)
    pred <- predict(fit, newdata = te)
    cor(pred, te[[trait]], use = "complete.obs")
  }) %>% mean(na.rm = TRUE)
}

if (length(vi_cols) > 0) {
  cat("Computing standard VI baselines for", length(vi_cols), "VIs ×",
      length(usable_traits), "traits ...\n")
  std_vi_results <- expand_grid(vi = vi_cols, trait = usable_traits) %>%
    mutate(mean_r = map2_dbl(vi, trait, ~linreg_cv(model_data, .x, .y)))

  best_std_vi <- std_vi_results %>%
    group_by(trait) %>%
    slice_max(mean_r, n = 1, with_ties = FALSE) %>%
    ungroup() %>%
    rename(best_vi = vi, std_r = mean_r)

  comparison <- cv_summary %>%
    select(trait, syn_r = mean_r) %>%
    left_join(best_std_vi, by = "trait") %>%
    mutate(improvement = syn_r - std_r)

  comparison %>%
    arrange(desc(improvement)) %>%
    kable(digits = 3,
          col.names = c("Trait","Synthetic VI r","Best std VI","Std VI r","Δr"),
          caption = "Synthetic VI vs. best standard VI (LOEO mean Pearson r)") %>%
    kable_styling(bootstrap_options = c("striped","hover","condensed"),
                  full_width = FALSE) %>%
    column_spec(5,
                bold  = TRUE,
                color = ifelse(comparison$improvement > 0, "green", "red"))
}
```

