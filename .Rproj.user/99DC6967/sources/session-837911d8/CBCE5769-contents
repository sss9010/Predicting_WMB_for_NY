# DNN Architecture

The network has two components:

1. **Band Encoder** — three fully-connected layers (16 → 8 → 1).
   The single output neuron is the *Synthetic VI* (no activation, so it can
   be any real value).

2. **Prediction Head** — takes [Synthetic VI, Environment Embedding (dim 4)]
   and maps through two layers to a scalar trait prediction.

By keeping the bottleneck at width 1, the network is forced to compress all
spectral information into a single derived index before predicting the trait.

```{r dnn-definition}
# ══════════════════════════════════════════════════════════════════════════
# Band Encoder module: 5 bands → Synthetic VI (scalar)
# ══════════════════════════════════════════════════════════════════════════
BandEncoder <- nn_module(
  classname = "BandEncoder",
  initialize = function(n_bands = 5, h1 = 16, h2 = 8) {
    self$fc1 <- nn_linear(n_bands, h1)
    self$fc2 <- nn_linear(h1, h2)
    self$fc3 <- nn_linear(h2, 1)   # bottleneck = Synthetic VI
    self$bn1 <- nn_batch_norm1d(h1)
    self$bn2 <- nn_batch_norm1d(h2)
    self$drop <- nn_dropout(0.1)
  },
  forward = function(x) {
    x <- x %>% self$fc1() %>% self$bn1() %>% nnf_relu() %>% self$drop()
    x <- x %>% self$fc2() %>% self$bn2() %>% nnf_relu() %>% self$drop()
    self$fc3(x)   # linear output
  }
)

# ══════════════════════════════════════════════════════════════════════════
# Full predictor: encoder + environment embedding + prediction head
# ══════════════════════════════════════════════════════════════════════════
SyntheticVIModel <- nn_module(
  classname = "SyntheticVIModel",
  initialize = function(n_bands = 5, n_envs = 5, env_dim = 4,
                        h1 = 16, h2 = 8, pred_h = 16) {
    self$encoder  <- BandEncoder(n_bands, h1, h2)
    self$env_emb  <- nn_embedding(n_envs, env_dim)
    # prediction head: VI (1) + env embedding (env_dim) → trait
    self$pred_fc1 <- nn_linear(1 + env_dim, pred_h)
    self$pred_bn  <- nn_batch_norm1d(pred_h)
    self$pred_fc2 <- nn_linear(pred_h, 1)
    self$drop     <- nn_dropout(0.1)
  },
  forward = function(bands, env_idx) {
    vi      <- self$encoder(bands)                  # (N, 1)
    env_e   <- self$env_emb(env_idx)               # (N, env_dim)
    x       <- torch_cat(list(vi, env_e), dim = 2) # (N, 1+env_dim)
    x <- x %>% self$pred_fc1() %>% self$pred_bn() %>% nnf_relu() %>% self$drop()
    self$pred_fc2(x)                                # (N, 1)
  },
  get_synthetic_vi = function(bands) {
    # Extract the bottleneck value without the prediction head
    self$encoder(bands)
  }
)

cat("Model architecture defined.\n")
cat("  Encoder:  5 bands → 16 → 8 → 1 (Synthetic VI)\n")
cat("  Predictor: [VI + Env(4)] → 16 → 1 (trait)\n")
```

# Training

Leave-one-environment-out (LOEO) cross-validation is used to evaluate
generalisation across trials and years. For each trait:

1. Train on all environments except one.
2. Predict the held-out environment.
3. Compute Pearson correlation (r) and RMSE on the original scale.

```{r training-functions}
# ── Helper: build tensors for one subset of model_data ────────────────────
make_tensors <- function(df, trait) {
  rows_ok  <- !is.na(df[[trait]])
  df_sub   <- df[rows_ok, ]
  list(
    bands   = torch_tensor(as.matrix(df_sub[, BAND_NAMES]), dtype = torch_float()),
    env_idx = torch_tensor(df_sub$env_idx, dtype = torch_long()),
    y       = torch_tensor(df_sub[[trait]], dtype = torch_float())$unsqueeze(2)
  )
}

# ── Training loop for a single trait / fold ────────────────────────────────
train_model <- function(train_df, trait, n_envs,
                        epochs = 150, lr = 5e-3, batch_size = 128,
                        verbose = FALSE) {
  tensors <- make_tensors(train_df, trait)
  n       <- tensors$bands$size(1)
  if (n < 10) return(NULL)

  model <- SyntheticVIModel(n_bands = length(BAND_NAMES), n_envs = n_envs,
                            env_dim = 4, h1 = 16, h2 = 8, pred_h = 16)
  opt   <- optim_adam(model$parameters, lr = lr, weight_decay = 1e-4)
  sched <- lr_step(opt, step_size = 60, gamma = 0.5)

  model$train()
  for (ep in seq_len(epochs)) {
    idx  <- sample(n)
    loss_ep <- 0
    for (i in seq(1, n, by = batch_size)) {
      bi      <- idx[i:min(i + batch_size - 1, n)]
      b_bands <- tensors$bands[bi, ]
      b_env   <- tensors$env_idx[bi]
      b_y     <- tensors$y[bi, ]

      opt$zero_grad()
      pred   <- model(b_bands, b_env)
      loss   <- nnf_mse_loss(pred, b_y)
      loss$backward()
      nn_utils_clip_grad_norm_(model$parameters, 1.0)
      opt$step()
      loss_ep <- loss_ep + loss$item()
    }
    sched$step()
    if (verbose && ep %% 50 == 0)
      cat(sprintf("  Epoch %3d | loss = %.4f\n", ep, loss_ep))
  }
  model$eval()
  model
}

# ── LOEO cross-validation for one trait ────────────────────────────────────
loeo_cv <- function(data, trait, n_envs, epochs = 150,
                    lr = 5e-3, batch_size = 128) {
  envs <- env_levels
  results <- map_dfr(envs, function(test_env) {
    train_df <- data %>% filter(Env != test_env)
    test_df  <- data %>% filter(Env == test_env)

    model <- tryCatch(
      train_model(train_df, trait, n_envs = n_envs,
                  epochs = epochs, lr = lr, batch_size = batch_size),
      error = function(e) { message("Error in train_model: ", e$message); NULL }
    )
    if (is.null(model)) {
      return(tibble(Env = test_env, n = 0, r = NA_real_, rmse = NA_real_))
    }

    ten  <- make_tensors(test_df, trait)
    if (ten$bands$size(1) < 2)
      return(tibble(Env = test_env, n = 0, r = NA_real_, rmse = NA_real_))

    with_no_grad({
      pred_z <- model(ten$bands, ten$env_idx)$squeeze()$to(device = "cpu")
    })
    pred_z <- as.numeric(pred_z)
    obs_z  <- as.numeric(ten$y$squeeze())

    # back-transform from z-score
    sc     <- trait_scale[[trait]]
    pred   <- pred_z * sc$sd + sc$mean
    obs    <- obs_z  * sc$sd + sc$mean

    tibble(
      Env  = test_env,
      n    = length(obs),
      r    = cor(pred, obs, use = "complete.obs"),
      rmse = sqrt(mean((pred - obs)^2, na.rm = TRUE))
    )
  })
  results
}
```

